m1, m2, m3, m4 = map(int, input().split())
total = m1+m2+m3+m4
average = total/4;
print(total)
print(f"{average:.2f}")
if average >= 75:
	print("Distinction")
elif average >= 60:
	print("First Division")
elif average >= 50:
	print("Second Division")
elif average >= 40:
	print("Third Division")
else:
	print("Fail")
